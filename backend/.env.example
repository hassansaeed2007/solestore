PORT=5000
MONGO_URI=mongodb://localhost:27017/shoestore
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gmail SMTP — use App Password (NOT your real Gmail password)
# Steps: Gmail → Google Account → Security → 2-Step Verification → App Passwords → Generate
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

NODE_ENV=development
CLIENT_URL=http://localhost:3000
